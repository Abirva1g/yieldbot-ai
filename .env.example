# YieldBot AI Environment Configuration Template
# Copy this file to .env and fill in your values

# Solana Configuration (Devnet by default for safe testing)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Wallet Configuration (Devnet ONLY - NEVER use mainnet keys!)
# Get your private key from Phantom/Solflare wallet (export as Base58 string)
WALLET_PRIVATE_KEY=your_base58_private_key_here

# Jupiter Configuration
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Analyzer Configuration
ANALYZER_EMA_PERIOD=10
ANALYZER_MIN_PROFIT_THRESHOLD_BPS=50
ANALYZER_MAX_DEVIATION_BPS=500
ANALYZER_MAX_HOPS=2

# Executor Configuration
EXECUTOR_MAX_RETRIES=3
EXECUTOR_PRIORITY_FEE_STATIC=50000
EXECUTOR_SLIPPAGE_BPS=50

# Monitor Configuration
MONITOR_DEGRADED_FAILURE_THRESHOLD=2
MONITOR_CRITICAL_FAILURE_THRESHOLD=5
MONITOR_DEGRADED_SUCCESS_RATE_THRESHOLD=0.8
MONITOR_CRITICAL_SUCCESS_RATE_THRESHOLD=0.5
MONITOR_COOLDOWN_MINUTES=5

# OpenAI Configuration (optional for MVP)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o

# AWS Configuration (for Phase 3 - Confidential Compute)
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_SECRET_ID=yieldbot-private-keys

# Telegram Configuration (for alerts and commands)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
